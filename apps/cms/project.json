{
  "name": "cms",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "tslmai-angular16-apps",
  "sourceRoot": "apps/cms/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:browser",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/cms",
        "index": "apps/cms/src/index.html",
        "main": "apps/cms/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/cms/tsconfig.app.json",
        "assets": ["apps/cms/src/favicon.ico", "apps/cms/src/assets"],
        "styles": ["apps/cms/src/styles.scss"],
        "scripts": [],
        "optimization": true,
        "sourceMap": false,
        "namedChunks": false,
        "aot": true
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1.5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "10kb"
            }
          ],
          "outputHashing": "all",
          "buildOptimizer": true,
          "optimization": true,
          "vendorChunk": false,
          "extractLicenses": true,
          "sourceMap": false,
          "namedChunks": false,
          "fileReplacements": [
            {
              "replace": "apps/cms/src/environments/environment.ts",
              "with": "apps/cms/src/environments/environment.prod.ts"
            }
          ]
        },
        "development": {
          "buildOptimizer": false,
          "optimization": false,
          "vendorChunk": true,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true,
          "fileReplacements": [
            {
              "replace": "apps/cms/src/environments/environment.prod.ts",
              "with": "apps/cms/src/environments/environment.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "browserTarget": "cms:build:production"
        },
        "development": {
          "browserTarget": "cms:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "browserTarget": "cms:build"
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/cms/**/*.ts", "apps/cms/**/*.html"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/cms/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "cms:build"
      }
    }
  }
}
